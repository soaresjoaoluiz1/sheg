# --- Banco ---
# Local dev: rode um Postgres (docker run --name shegou-pg -e POSTGRES_USER=shegou -e POSTGRES_PASSWORD=shegou -e POSTGRES_DB=shegou -p 5432:5432 -d postgres:16-alpine)
DATABASE_URL="postgresql://shegou:shegou@localhost:5432/shegou?schema=public"

# --- Auth ---
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# --- Uploads ---
UPLOADS_DIR="./public/uploads"
UPLOADS_PUBLIC_PATH="/uploads"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- WhatsApp (Evolution API) — opcional, deixa em branco pra mock ---
EVOLUTION_BASE_URL=""
EVOLUTION_API_KEY=""
