# Copie este arquivo para .env.production no servidor e preencha os valores reais.
# NUNCA commite .env.production no git.

# Domínio (sem protocolo) — Traefik usa pra rotear + emitir SSL
APP_DOMAIN=sheraos.com.br

# Caminho base onde a app fica (vazio = raiz, "/shegou" = subpasta)
NEXT_PUBLIC_BASE_PATH=/shegou

# URL pública completa
NEXT_PUBLIC_APP_URL=https://sheraos.com.br/shegou

# Postgres (interno ao docker-compose)
POSTGRES_USER=shegou
POSTGRES_PASSWORD=trocar-por-senha-forte-aleatoria
POSTGRES_DB=shegou

# Auth
JWT_SECRET=gerar-com-openssl-rand-base64-32
JWT_EXPIRES_IN=7d

# WhatsApp via Evolution API (opcional — deixa em branco pra modo mock)
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
