# Copie este arquivo para .env.production no servidor e preencha os valores reais.
# NUNCA commite .env.production no git.

# Domínio onde a aplicação será exposta (Traefik usa pra rotear + emitir SSL)
APP_DOMAIN=shegou.sheraos.com.br
NEXT_PUBLIC_APP_URL=https://shegou.sheraos.com.br

# Postgres (interno ao docker-compose; só esses 3 são usados pra montar a DATABASE_URL)
POSTGRES_USER=shegou
POSTGRES_PASSWORD=trocar-por-senha-forte-aleatoria
POSTGRES_DB=shegou

# Auth
JWT_SECRET=gerar-com-openssl-rand-base64-32
JWT_EXPIRES_IN=7d

# WhatsApp via Evolution API (opcional — deixa em branco pra modo mock)
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
